# =============================================================================
# Gitignore Template
# 包含：VSCode, Python, uv, macOS, Windows, Log 等常見忽略檔
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.log

# virtual environments
venv/
ENV/
env/
.venv/
pipenv-lock*
Python-3.11.5.yaml

# uv (modern Python package manager)
# uv會在專案根目錄創建 .venv 目錄
.venv/
uv.lock

# -----------------------------------------------------------------------------
# VSCode
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.apdisk

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
# Windows thumbnail cache files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs.db:encryptable

# Windows folder level cache files
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Icon must end with two \r
Icon
\r\r

# Session files
*.session

# Windows Installer
*.msi
*.msm
*.msp

# Application files
*.app
*.exe
*.dll
*.bat
*.cmd

# -----------------------------------------------------------------------------
# Log / 臨時檔案
# -----------------------------------------------------------------------------
*.log
logs/
*.log.*

# tmp / temp files
tmp/
temp/
*.tmp
*.bak
*.backup
*.swp
*.swo
*~

# =============================================================================
# 進階忽略規則
# =============================================================================

# IDE / Editor
.idea/
*.iml
*.iws
.vim/
*.sublime-*

# Environment files (包含敏感資訊)
.env
.env.local
.env.*.local

# Test coverage reports
coverage/
*.lcov

# Node (如果有用)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn-integrity

# Terraform (如果有用)
*.tfstate
*.tfstate.*
.terraform/